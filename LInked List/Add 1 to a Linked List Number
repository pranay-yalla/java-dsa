/* Structure of linked list Node
class Node {
	int data;
	Node next;
	
	Node(int x) {
		data = x;
		next = null;
	}
}
*/
class Solution {
	public Node addOne(Node head) {
		if (head == null)
			return new Node(1);
		head = reverse(head);
		
		// head=prev;
		Node temp = head;
		boolean carry = true;
		while (temp.next != null)
			{
			if (temp.data <= 8 && carry == true)
				{
				temp.data += 1;
				carry = false;
				head = reverse(head);
				return head;
			}
			else
				{
				carry = true;
				temp.data = 0;
				temp = temp.next;
			}
		}
		if (temp.data <= 8)
			{
			temp.data += 1;
			head = reverse(head);
			return head;
		}
		else
			{
			temp.data = 0;
			temp.next = new Node(1);
		}
		
		head = reverse(head);
		return head;
		// code here.
	}
	static Node reverse(Node head) {
		Node prev = null, temp = head;
		while (temp != null)
			{
			Node next = temp.next;
			temp.next = prev;
			prev = temp;
			temp = next;
		}
		head = prev;
		return head;
	}
}
