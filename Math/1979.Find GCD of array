class Solution {
    public int findGCD(int[] a) {
        int small=a[0], big=a[0];
        for(int i=1;i<a.length;i++){
            if(a[i]>big)
            big=a[i];
            if(a[i]<small)
            small=a[i];
        }
while(small>0 && big>0)
{
	int temp=small;
	small=big%small;
	big=temp;
	 }
	
	return big;
    }
}
